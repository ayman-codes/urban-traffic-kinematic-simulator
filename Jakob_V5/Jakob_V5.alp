	<Experiments>
		<!--   =========   Simulation Experiment   ========  -->
		<SimulationExperiment ActiveObjectClassId="1777539703306">
			<Id>1777539703314</Id>
			<Name><![CDATA[Simulation]]></Name>
			<CommandLineArguments><![CDATA[]]></CommandLineArguments>
			<MaximumMemory>512</MaximumMemory>
			<RandomNumberGenerationType>randomSeed</RandomNumberGenerationType>
			<CustomGeneratorCode>new Random()</CustomGeneratorCode>
			<AfterSimulationRunCode><![CDATA[System.out.println("--- S1 INTERSECTION FINAL REPORT ---");

// Calculates the true, time-weighted average queue length over the whole run for values > 0
double avgS1_SN = root.countPos_S1_SN > 0 ? root.sumPos_S1_SN / root.countPos_S1_SN : 0;
System.out.println("Average Queue Length at S1 from S->N (>0 only): " + avgS1_SN);

double avgS2_SN = root.countPos_S2_SN > 0 ? root.sumPos_S2_SN / root.countPos_S2_SN : 0;
System.out.println("Average Queue Length at S2 from S->N (>0 only): " + avgS2_SN);

double avgS3_SN = root.countPos_S3_SN > 0 ? root.sumPos_S3_SN / root.countPos_S3_SN : 0;
System.out.println("Average Queue Length at S3 from S->N (>0 only): " + avgS3_SN);

double avgS4_SN = root.countPos_S4_SN > 0 ? root.sumPos_S4_SN / root.countPos_S4_SN : 0;
System.out.println("Average Queue Length at S4 from S->N (>0 only): " + avgS4_SN);

double avgS1_NS = root.countPos_S1_NS > 0 ? root.sumPos_S1_NS / root.countPos_S1_NS : 0;
System.out.println("Average Queue Length at S1 from N->S (>0 only): " + avgS1_NS);

double avgS2_NS = root.countPos_S2_NS > 0 ? root.sumPos_S2_NS / root.countPos_S2_NS : 0;
System.out.println("Average Queue Length at S2 from N->S (>0 only): " + avgS2_NS);

double avgS3_NS = root.countPos_S3_NS > 0 ? root.sumPos_S3_NS / root.countPos_S3_NS : 0;
System.out.println("Average Queue Length at S3 from N->S (>0 only): " + avgS3_NS);

double avgS4_NS = root.countPos_S4_NS > 0 ? root.sumPos_S4_NS / root.countPos_S4_NS : 0;
System.out.println("Average Queue Length at S4 from N->S (>0 only): " + avgS4_NS);

// Calculates the true, time-weighted average queue length over the whole run
//double avgS1_SN = root.stats_S1_queue_right.mean();
//System.out.println("Average Queue Length at S1 from S->N : " + avgS1_SN);
//double avgS2_SN = root.stats_S2_queue_right.mean();
//System.out.println("Average Queue Length at S2 from S->N : " + avgS2_SN);
//double avgS3_SN = root.stats_S3_queue_right.mean();
//System.out.println("Average Queue Length at S3 from S->N : " + avgS3_SN);
//double avgS4_SN = root.stats_S4_queue_right.mean();
//System.out.println("Average Queue Length at S4 from S->N : " + avgS4_SN);
//double avgS1_NS = root.stats_S1_queue_left.mean();
//System.out.println("Average Queue Length at S1 from N->S : " + avgS1_NS);
//double avgS2_NS = root.stats_S2_queue_left.mean();
//System.out.println("Average Queue Length at S2 from N->S : " + avgS2_NS);
//double avgS3_NS = root.stats_S3_queue_left.mean();
//System.out.println("Average Queue Length at S3 from N->S : " + avgS3_NS);
//double avgS4_NS = root.stats_S4_queue_left.mean();
//System.out.println("Average Queue Length at S4 from N->S : " + avgS4_NS);


// Captures the highest traffic spike/jam registered during the simulation
double maxS1_SN = root.stats_S1_queue_right.max();
System.out.println("Maximum Peak Queue Length at S1 from S->N : " + maxS1_SN);
double maxS2_SN = root.stats_S2_queue_right.max();
System.out.println("Maximum Peak Queue Length at S2 from S->N : " + maxS2_SN);
double maxS3_SN = root.stats_S3_queue_right.max();
System.out.println("Maximum Peak Queue Length at S3 from S->N : " + maxS3_SN);
double maxS4_SN = root.stats_S4_queue_right.max();
System.out.println("Maximum Peak Queue Length at S4 from S->N : " + maxS4_SN);
double maxS1_NS = root.stats_S1_queue_left.max();
System.out.println("Maximum Peak Queue Length at S1 from N->S : " + maxS1_NS);
double maxS2_NS = root.stats_S2_queue_left.max();
System.out.println("Maximum Peak Queue Length at S2 from N->S : " + maxS2_NS);
double maxS3_NS = root.stats_S3_queue_left.max();
System.out.println("Maximum Peak Queue Length at S3 from N->S : " + maxS3_NS);
double maxS4_NS = root.stats_S4_queue_left.max();
System.out.println("Maximum Peak Queue Length at S4 from N->S : " + maxS4_NS);

System.out.println("------------------------------------");


double throughput_ee = root.carDispose_EE1.count() + root.carDispose_EE2.count() + root.carDispose_EE3.count() + root.carDispose_EE4.count() + root.carDispose_rev_EE2.count() + root.carDispose_rev_EE3.count() +root.carDispose_rev_EE4.count();
System.out.println("Total Network Throughput for East exit lanes is : " + throughput_ee);

double throughput_we = root.carDispose_WE1.count() + root.carDispose_WE2.count() + root.carDispose_WE3.count()  + root.carDispose_rev_WE1.count() + root.carDispose_rev_WE2.count() +root.carDispose_rev_WE3.count();
System.out.println("Total Network Throughput for West exit lanes is : " + throughput_we);

double total_throughput = root.carDispose.count() + root.carDispose_Allee.count() + throughput_ee + throughput_we;
System.out.println("Total Network Throughput for system is : " + total_throughput);

double total_throughput_main_road = root.carDispose.count() + root.carDispose_Allee.count() ;
System.out.println("Total Throughput for Main Road is : " + total_throughput_main_road);
]]></AfterSimulationRunCode>
