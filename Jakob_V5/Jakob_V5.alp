			<AfterExperimentCode><![CDATA[// Define Column Headers
String[] headers = {
    "avgS1_SN", "avgS2_SN", "avgS3_SN", "avgS4_SN", 
    "avgS1_NS", "avgS2_NS", "avgS3_NS", "avgS4_NS",
    "maxS1_SN", "maxS2_SN", "maxS3_SN", "maxS4_SN", 
    "maxS1_NS", "maxS2_NS", "maxS3_NS", "maxS4_NS",
    "throughput_ee", "throughput_es", "total_throughput", "total_throughput_main_road"
};

// Write Headers to Row 1
for (int col = 0; col < headers.length; col++) {
    excelFile.setCellValue(headers[col], "Tabelle1", 1, col + 1);
}

// Loop through all 100 stored runs and write to Excel
for (int row = 0; row < 100; row++) {
    for (int col = 0; col < 20; col++) {
        // row + 2 ensures data starts on Row 2 of Excel (below headers)
        excelFile.setCellValue(myRawValues[row][col], "Tabelle1", row + 2, col + 1);
    }
}

// write to excel file
// if you want to change/add something let me know first
excelFile.writeFile();
System.out.println("--- S1 INTERSECTION EXCEL EXPORT COMPLETE ---");
]]></AfterExperimentCode>
