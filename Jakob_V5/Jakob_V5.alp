			<AfterSimulationRunCode><![CDATA[// Getting the current run iteration
int runIndex = getCurrentIteration() - 1;

// Only pull data if within our 100-run bounds
// DO NOT CHANGE CODE HERE!
if (runIndex >= 0 && runIndex < 100) {

    // --- Calculate the complex metrics from root ---
    double throughput_ee = root.carDispose_EE1.count() + root.carDispose_EE2.count() + root.carDispose_EE3.count() + root.carDispose_EE4.count() + root.carDispose_rev_EE2.count() + root.carDispose_rev_EE3.count() + root.carDispose_rev_EE4.count();
    double throughput_we = root.carDispose_WE1.count() + root.carDispose_WE2.count() + root.carDispose_WE3.count() + root.carDispose_rev_WE1.count() + root.carDispose_rev_WE2.count() + root.carDispose_rev_WE3.count();
    double throughput_main_road = root.carDispose.count() + root.carDispose_Allee.count();
    double total_throughput = throughput_main_road + throughput_ee + throughput_we;
    
    // --- Populate the columns ---
    myRawValues[runIndex][0] = root.countPos_S1_SN > 0 ? root.sumPos_S1_SN / root.countPos_S1_SN : 0;
    myRawValues[runIndex][1] = root.countPos_S2_SN > 0 ? root.sumPos_S2_SN / root.countPos_S2_SN : 0;
    myRawValues[runIndex][2] = root.countPos_S3_SN > 0 ? root.sumPos_S3_SN / root.countPos_S3_SN : 0;
    myRawValues[runIndex][3] = root.countPos_S4_SN > 0 ? root.sumPos_S4_SN / root.countPos_S4_SN : 0;
    myRawValues[runIndex][4] = root.countPos_S1_NS > 0 ? root.sumPos_S1_NS / root.countPos_S1_NS : 0;
    myRawValues[runIndex][5] = root.countPos_S2_NS > 0 ? root.sumPos_S2_NS / root.countPos_S2_NS : 0;
    myRawValues[runIndex][6] = root.countPos_S3_NS > 0 ? root.sumPos_S3_NS / root.countPos_S3_NS : 0;
    myRawValues[runIndex][7] = root.countPos_S4_NS > 0 ? root.sumPos_S4_NS / root.countPos_S4_NS : 0;

    myRawValues[runIndex][8] = root.stats_S1_queue_right.max();
    myRawValues[runIndex][9] = root.stats_S2_queue_right.max();
    myRawValues[runIndex][10] = root.stats_S3_queue_right.max();
    myRawValues[runIndex][11] = root.stats_S4_queue_right.max();
    myRawValues[runIndex][12] = root.stats_S1_queue_left.max();
    myRawValues[runIndex][13] = root.stats_S2_queue_left.max();
    myRawValues[runIndex][14] = root.stats_S3_queue_left.max();
    myRawValues[runIndex][15] = root.stats_S4_queue_left.max();

    myRawValues[runIndex][16] = throughput_ee;
    myRawValues[runIndex][17] = throughput_we;
    myRawValues[runIndex][18] = total_throughput;
    myRawValues[runIndex][19] = throughput_main_road;
}]]></AfterSimulationRunCode>
